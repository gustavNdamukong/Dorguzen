APP_NAME=""
APP_ENV=local # options: [testing, local, staging, prod]
APP_SLOGAN=''
APP_LAYOUT_DIR='projectName'
APP_DEFAULT_LAYOUT_DIR='projectNameLayout'
APP_LOCAL_URL='http://localhost/projectName/'
APP_LIVE_URL='https://projectDomain/'
APP_LIVE_URL_SECURE='https://projectDomain/'
APP_FILE_ROOT_LOCAL='/projectName/'
APP_FILE_ROOT_LIVE='/'
APP_DEBUG=true
APP_URL=https://projectDomain

# DATABASE CONNECTION
DB_CONNECTION=mysqli # options: [mysqli, pdo, sqlite, pgsql]  
DB_HOST=127.0.0.1
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
DB_PORT=3306 # 3306 for mysql or 5432 for pgsql (postgres)

DB_KEY=testOnlyKeyForPasswordHashing # Optional-only if your hashing method requires it, e.g. AES_ENCRYPT

# SQLite (used only when DB_CONNECTION=sqlite).
# SQLite needs ONLY one credential line-a file path.
# SQLite does not use DB_DATABASE as a name — it uses a file path.
# SQLite will work perfectly with this one line for local, staging, and production environments.
# This file-based path ensures data is stored on disk, and so is persisted. The other SQLite mode 
# is :memory, which is ephemeral (stores data in memory), which is fast but temporal. :memory is 
# only recommended for use in testing-which does not need any data persistence. 
# Just make sure you create the 'storage/database.sqlite', or the 'storage/' directory and 
# make it both writeable and readable. 
# Have no preceeding slash before 'storage'. 
DB_SQLITE_PATH=storage/database.sqlite

# LOGGING (using DGZ_Logger)
APP_LOG_DRIVER=both # options: [both=file & db, file, db]
APP_LOG_FORMAT=text

# Slack Incoming Webhooks (https://api.slack.com/apps → Incoming Webhooks)
# Create a webhook for your workspace there, then paste the URL below, and call:
#   DGZ_Slack::send('Hello!');
SLACK_WEBHOOK_URL=
SLACK_DEFAULT_CHANNEL=#general   # optional — overrides the webhook's own default channel
SLACK_USERNAME=                  # optional — bot display name (defaults to APP_NAME)
SLACK_ICON_EMOJI=:bell:          # optional — emoji icon shown next to the bot name

# Firebase JWT for API authentication
APP_JWT_SECRET='xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'
APP_JWT_ENCODING='HS256'

# Modules
MODULES_SEO_STATUS=on
MODULES_PAYMENTS_STATUS=off
MODULES_SMS_STATUS=on

# Make CSRF exception for API requests
APP_API_CSRF_EXCEPTION='/api/'

ALLOW_REGISTRATION=false

LIVE_ENV=true

# Queue driver — options: [sync, db, rabbitmq]
# 'sync'     — jobs run inline, no worker needed (default)
# 'db'       — jobs persisted to dgz_jobs table, run by: php dgz queue:work
# 'rabbitmq' — jobs sent to RabbitMQ broker; requires: composer require php-amqplib/php-amqplib
QUEUE_DRIVER=sync

# RabbitMQ connection (only used when QUEUE_DRIVER=rabbitmq)
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=default

# Cache & session drivers
CACHE_DRIVER=file
SESSION_DRIVER=file

NUM_LATEST_POSTS_TO_SHOW=15
MAX_UPLOAD_FILE_SIZE=10240000000

# Image upload target directories
DEFAULT_IMAGE_DIR='images/'
EMAIL_IMAGE_DIR='assets/images/email_images/' 
AUDIO_UPLOAD_DIR='docs/audios/'
VIDEO_UPLOAD_DIR='docs/videos/'
PRODUCT_UPLOAD_DIR='users/u_priv_imgs/'
BIZ_ADS_UPLOAD_DIR='users/bizAds/'

SLIDER_TYPE='slider'

# Locale
LOCALE='en'
FALL_BACK_LOCALE='en'


# Application contact details
APP_CONTACT_TEL='xxxxxxxxxx'
APP_POST_ADDRESS=''
# APP_EMAIL='admin@camerooncom.com' # We recommend you use one created on your web host's domain
APP_EMAIL='' # We recommend you use one created on your web host's domain
APP_SECOND_EMAIL='' # this can be used for CCing contacts,
LOCAL_HEADER_FROM='' # These should match the appEmail value
PROD_HEADER_FROM=''
HEADER_REPLY_TO=''


# SMTP / Mail
#---------------------------------
# MAILGUN CREDENTIALS USING SMTP / Mail (PHPMailer)
# Switch MAIL_HOST, PORT, USERNAME & PASSWORD to MailTrap for local testing.
# Uncomment this group to send emails in production 
#---------------------------------
# MAIL_HOST=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USERNAME=''
# MAIL_PASSWORD=''
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=''  # e.g. noreply@yourdomain.com
# MAIL_FROM_NAME=''     # e.g. "Your App Name"


#---------------------------------
# MAILTRAP TESTING
# Uncomment this group to test in the local environment
# Point at MailTrap (or any mail-catcher) during development — just change these values.
# For MailTrap: Host=sandbox.smtp.mailtrap.io, Port=587, Encryption=tls
#---------------------------------
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME='<mailtrap-sandbox-username>'
MAIL_PASSWORD=<mailtrap-password>

# API Documentation (Swagger UI at /api/v1/docs)
# Set to true to enable. Recommended: false in production.
API_DOCS_ENABLED=true


# Stripe (https://dashboard.stripe.com/apikeys)
# Use the test key locally; swap to the live secret key in production.
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_


# Twilio SMS (https://console.twilio.com)
# SID and Auth Token are on the main console dashboard.
# FROM_NUMBER is your purchased Twilio number (+E.164 format, e.g. +13656542054).
# TO_NUMBER is used only for the demo notify() action — remove or replace with a dynamic value in production.
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=
